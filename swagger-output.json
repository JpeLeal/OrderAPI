{
  "openapi": "3.0.0",
  "info": {
    "title": "OrderAPI",
    "description": "API REST para gerenciamento de pedidos",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:3000"
    }
  ],
  "tags": [
    {
      "name": "Orders",
      "description": "Operações relacionadas a pedidos"
    }
  ],
  "paths": {
    "/order/": {
      "post": {
        "tags": [
          "Orders"
        ],
        "summary": "Cria um novo pedido",
        "description": "",
        "responses": {
          "201": {
            "description": "Pedido criado com sucesso"
          },
          "400": {
            "description": "Inconsistência de valores"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "numeroPedido": 123,
                "valorTotal": 100,
                "dataCriacao": "2026-03-09T12:00:00.000Z",
                "items": [
                  {
                    "idItem": 1,
                    "quantidadeItem": 2,
                    "valorItem": 50
                  }
                ]
              }
            }
          }
        }
      }
    },
    "/order/list": {
      "get": {
        "tags": [
          "Orders"
        ],
        "summary": "Lista todos os pedidos",
        "description": "",
        "responses": {
          "200": {
            "description": "Lista de pedidos retornada com sucesso"
          },
          "500": {
            "description": "Erro ao listar pedidos"
          }
        }
      }
    },
    "/order/{id}": {
      "get": {
        "tags": [
          "Orders"
        ],
        "summary": "Busca um pedido por ID",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID do pedido"
          }
        ],
        "responses": {
          "200": {
            "description": "Pedido encontrado com sucesso"
          },
          "404": {
            "description": "Pedido não encontrado"
          },
          "500": {
            "description": "Erro interno do servidor"
          }
        }
      },
      "put": {
        "tags": [
          "Orders"
        ],
        "summary": "Atualiza um pedido existente",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID do pedido"
          }
        ],
        "responses": {
          "200": {
            "description": "Pedido atualizado com sucesso"
          },
          "400": {
            "description": "Inconsistência de valores"
          },
          "404": {
            "description": "Pedido não encontrado"
          },
          "500": {
            "description": "Erro ao tentar atualizar pedido"
          }
        },
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "valorTotal": 120,
                "dataCriacao": "2026-03-09T12:00:00.000Z",
                "items": [
                  {
                    "idItem": 10,
                    "quantidadeItem": 3,
                    "valorItem": 40
                  }
                ]
              }
            }
          }
        }
      },
      "delete": {
        "tags": [
          "Orders"
        ],
        "summary": "Remove um pedido por ID",
        "description": "",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "ID do pedido"
          }
        ],
        "responses": {
          "200": {
            "description": "Pedido deletado com sucesso"
          },
          "404": {
            "description": "Pedido inexistente"
          },
          "500": {
            "description": "Erro ao tentar deletar pedido"
          }
        }
      }
    }
  }
}